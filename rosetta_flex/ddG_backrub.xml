<!--
  Flex ddG protocol (Barlow et al., J Phys Chem B 2018) for TCR-pMHC interfaces.

  This is the canonical Kortemme-Lab flex_ddG RosettaScripts protocol, kept
  verbatim in structure so results are comparable to the published method. It:
    1. Constrains the input to its starting coordinates (AddConstraints).
    2. Runs `backrubT` backrub trials to build a conformational ensemble.
    3. Repacks/minimizes WT and mutant (the mutation is supplied per-job via the
       `resfile` script-var written by make_mutfiles.py).
    4. Reports a ReportToDB ddG.db3 SQLite file that run_flex_ddg.py parses.

  Per-job script-vars (set on the rosetta_scripts command line; see
  run_flex_ddg.py): chainstomove, pathtoresfile, currentscorefxn, backrubntrials.

  DO NOT run locally (this is launched on HPC via submit_array.sbatch).
-->
<ROSETTASCRIPTS>
  <SCOREFXNS>
    <ScoreFunction name="fa_talaris2014" weights="talaris2014"/>
    <ScoreFunction name="fa_talaris2014_cst" weights="talaris2014">
      <Reweight scoretype="atom_pair_constraint" weight="1.0"/>
      <Set fa_max_dis="9.0"/>
    </ScoreFunction>
  </SCOREFXNS>

  <RESIDUE_SELECTORS>
    <Task name="resselector" fixed="0" packable="0" designable="1" task_operations="mutate"/>
    <Neighborhood name="bubble" selector="resselector" distance="8.0"/>
    <PrimarySequenceNeighborhood name="bubble_adjacent" selector="bubble" lower="1" upper="1"/>
    <StoredResidueSubset name="restore_neighbor_shell" subset_name="neighbor_shell"/>
    <Not name="everythingelse" selector="restore_neighbor_shell"/>
  </RESIDUE_SELECTORS>

  <TASKOPERATIONS>
    <ReadResfile name="mutate" filename="%%pathtoresfile%%"/>
    <InitializeFromCommandline name="commandline"/>
    <OperateOnResidueSubset name="repackonly" selector="restore_neighbor_shell">
      <RestrictToRepackingRLT/>
    </OperateOnResidueSubset>
    <OperateOnResidueSubset name="norepack" selector="everythingelse">
      <PreventRepackingRLT/>
    </OperateOnResidueSubset>
    <UseMultiCoolAnnealer name="multicool" states="6"/>
    <ExtraChiCutoff name="extrachizero" extrachi_cutoff="0"/>
    <ExtraRotamersGeneric name="extrachi" ex1="1" ex2="1" ex1aro="1" extrachi_cutoff="0"/>
  </TASKOPERATIONS>

  <FILTERS>
  </FILTERS>

  <MOVERS>
    <StoreResidueSubset name="neighbor_shell_storer" subset_name="neighbor_shell" residue_selector="bubble_adjacent"/>

    <AddConstraintsToCurrentConformationMover name="addcst" use_distance_cst="1" coord_dev="0.5"
        min_seq_sep="0" max_distance="9" CA_only="1" bound_width="0.0" cst_weight="0.0"/>
    <ClearConstraintsMover name="clearcst"/>

    <MinMover name="minimize" scorefxn="fa_talaris2014_cst" chi="1" bb="1" type="lbfgs_armijo_nonmonotone"
        tolerance="0.000001" max_iter="5000" abs_score_convergence_threshold="1.0"/>

    <PackRotamersMover name="repack" scorefxn="fa_talaris2014" task_operations="commandline,repackonly,norepack,multicool"/>
    <PackRotamersMover name="mutate" scorefxn="fa_talaris2014" task_operations="commandline,mutate,norepack,multicool"/>

    <ReportToDB name="dbreport" batch_description="interface_ddG" database_name="ddG.db3">
      <ScoreTypeFeatures/>
      <ScoreFunctionFeatures scorefxn="fa_talaris2014"/>
      <StructureScoresFeatures scorefxn="fa_talaris2014"/>
    </ReportToDB>

    <ReportToDB name="structreport" batch_description="interface_ddG_struct" database_name="struct.db3">
      <PoseConformationFeatures/>
      <PdbDataFeatures/>
      <JobDataFeatures/>
      <ResidueFeatures/>
      <PoseCommentsFeatures/>
      <ProteinResidueConformationFeatures/>
      <ResidueConformationFeatures/>
    </ReportToDB>

    <SavePoseMover name="save_wt_bound_pose" restore_pose="0" reference_name="wt_bound_pose"/>
    <SavePoseMover name="save_backrub_pose" restore_pose="0" reference_name="backrubpdb"/>
    <SavePoseMover name="restore_to_backrub_pose" restore_pose="1" reference_name="backrubpdb"/>

    <InterfaceDdGMover name="int_ddG_mover" wt_ref_savepose_mover="save_wt_bound_pose"
        chain_name="%%chainstomove%%" constraint_weight="1.0"
        repack_bound="1" repack_unbound="1" relax_bound="0" relax_unbound="1"
        scorefxn="fa_talaris2014"/>

    <BackrubProtocol name="backrub" mc_kt="1.2" ntrials="%%backrubntrials%%" pivot_residue_selector="restore_neighbor_shell"
        require_mm_bend="0" recover_low="0" trajectory_stride="%%backrubntrials%%" trajectory_apx="backrub_traj"/>

    <ParsedProtocol name="finish_ddg_post_backrub">
      <Add mover="save_backrub_pose"/>
      <Add mover="repack"/>
      <Add mover="minimize"/>
      <Add mover="save_wt_bound_pose"/>
      <Add mover="int_ddG_mover"/>
      <Add mover="restore_to_backrub_pose"/>
      <Add mover="mutate"/>
      <Add mover="repack"/>
      <Add mover="minimize"/>
      <Add mover="int_ddG_mover"/>
    </ParsedProtocol>
  </MOVERS>

  <PROTOCOLS>
    <Add mover="addcst"/>
    <Add mover="neighbor_shell_storer"/>
    <Add mover="backrub"/>
    <Add mover="finish_ddg_post_backrub"/>
  </PROTOCOLS>

  <OUTPUT/>
</ROSETTASCRIPTS>
